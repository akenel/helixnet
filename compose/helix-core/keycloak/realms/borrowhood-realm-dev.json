  "roles": {
    "realm": [
      {
        "name": "bh-member",
        "description": "Basic community member. Can browse, rent items, leave reviews, manage own workshop profile."
      },
      {
        "name": "bh-lender",
        "description": "Verified lender. Can list items for rent/sale/service, manage listings, view rental requests."
      },
      {
        "name": "bh-moderator",
        "description": "Community moderator. Can review reports, suspend listings, issue warnings to users."
      },
      {
        "name": "bh-admin",
        "description": "Platform administrator. Full control over users, listings, reports, and system settings."
      },
      {
        "name": "bh-operator",
        "description": "Neighborhood operator. Manages a BorrowHood chapter, approves lenders, monitors activity."
      },
      {
        "name": "bh-qa-tester",
        "description": "QA tester. Testing dashboard, bug reporting, test execution, verification."
      },
      {
        "name": "default-roles-borrowhood",
        "description": "Default roles for borrowhood realm",
        "composite": true
      }
    ]
  },
