# ====================================================================
# 🔒 CRITICAL SECURITY & ENVIRONMENT (MUST BE IGNORED)
# ====================================================================
.env
.env.*
!*.env.example # Keep the template file if it exists

# Hetzner deploy env files (real secrets, NEVER commit)
hetzner/borrowhood.env
hetzner/.env.staging
hetzner/uat.env
hetzner/prod.env
# Templates with placeholders ARE tracked (no leading dot, suffix .template)
!hetzner/*.template

# SSH Keys (Avoid accidental commit from any directory)
**/id_ed25519
**/id_ed25519.pub

# Keycloak/Traefik Local Certificates (from mkcert)
*.pem
*.crt
*.key
# If using a specific directory for generated certs, ignore it:
traefik/certs/
app/traefik/dynamic/certs.yml


# ====================================================================
# ⚙️ VOLUMES, CACHES, ARTIFACTS, AND LARGE DATA (TARGETED IGNORES)
# ====================================================================
# Python Virtual Environments
venv/
.venv/
env/
# Specific Python Caches and Builds
__pycache__/
*.pyc
*.py[cod]
*$py.class
dist/
build/
*.egg-info/
.pytest_cache/
.mypy_cache/
.flake8
.coverage*
instance/ # Flask/Django instance folder if used

# Docker Volume Data (Critical to ignore massive binary data)
compose/**/postgres-data/
compose/**/cache/
compose/**/data/
compose/**/models/
compose/**/minio/
compose/**/qdrant/
compose/**/vector_db/
minio_data/
postgres_data/
redis_data/
portainer_data/
pgadmin_data/
celerybeat-schedule

# Local Data/Cache Directories (Non-containerized data)
data/
cache/
# ML models directory (not db models)
/models/

# ====================================================================
# 💻 IDE, OS, AND LOGS
# ====================================================================
# macOS/Windows/General OS Files
.DS_Store
Thumbs.db

# VS Code & Editor Files
.vscode/
.idea/
*.swp
*~
*.code-workspace

# Local Logs and Temporary Files
*.log
helix.logs
super_test_suite.log
# FourTwenty feed downloads (fetched daily, not tracked)
debllm/feeds/

# Large media files - keep local only
compose/helix-media/videos/
compose/helix-media/music/
*.mp4
*.mp3
*.m4a
*.flac
*.wav
.secrets/

# ====================================================================
# 🤝 CONFIDENTIAL BUSINESS DOCS (KEEP LOCAL)
# ====================================================================
# Paulo / Caffè Maltese partnership docs
docs/business/*Paulo*
docs/business/*NDA*
docs/business/*Partnership*
docs/business/*Platform-Partner*
docs/business/*POC-*
node_modules/

# ====================================================================
# 📁 POSTCARD WORKSHOP - Local Archives (not for repo)
# ====================================================================
# Arc folders keep previous versions locally for safety
# Git tracks the current versions; arc/ is the belt-and-suspenders
docs/business/postcards/**/arc/
# Raw photos from Telegram (large, unprocessed)
docs/business/postcards/**/raw/

# ====================================================================
# 🔑 KEYCLOAK MIGRATIONS - Local state tracking
# ====================================================================
scripts/kc-migrations/.applied

# ====================================================================
# 🧪 PLAYWRIGHT E2E TEST ARTIFACTS
# ====================================================================
test-results/
playwright-report/
tests/playwright-report/
tests/test-results/
.auth/

# ====================================================================
# 🎙️ WHISPER TRANSCRIPTS (personal voice notes named "* -- audio_*")
# ====================================================================
# These are voice memos from Telegram, transcribed by Whisper.
# They're personal scratch -- never committed.
* -- audio_*.json
* -- audio_*.srt
* -- audio_*.tsv
* -- audio_*.txt
* -- audio_*.vtt

# ====================================================================
# 📋 KDE/NAUTILUS DUPLICATE FILES (file manager copy-button residue)
# ====================================================================
* (copy).*
* (another copy).*
* ([0-9]rd copy).*
* ([0-9]nd copy).*
* ([0-9]th copy).*

# ====================================================================
# 📥 PARTIAL DOWNLOAD ORPHANS
# ====================================================================
*.mp4.part
*.crdownload
*.opdownload

# ====================================================================
# 🌐 BORROWHOOD IS ITS OWN GIT REPO -- never commit from helixnet
# ====================================================================
/BorrowHood/

# ====================================================================
# 🎬 VIDEO PIPELINE BINARIES
# Per CLAUDE.md: MP4s go to GDrive, not GitHub.
# Scoped to videos/ only -- assets/comics/**/*.mp4 are deliberate.
# ====================================================================
videos/**/*.mp4
videos/**/*.m4a
videos/**/*.ogg
videos/**/*.wav
videos/**/*.mp3

# Intermediate generation artifacts (mirrors the postcards/**/arc/ rule above)
videos/**/arc/
videos/**/frames/
videos/**/post-production/

# ====================================================================
# 📚 THIRD-PARTY TRAINING MATERIAL (copyright, retrievable elsewhere)
# ====================================================================
docs/training/*.pdf

# ====================================================================
# 🗄️ SERVER-SIDE CRUFT (Hetzner local backups + manual edits)
# ====================================================================
backups/
hetzner/Caddyfile.bak

# MemPalace per-project files (issue #185)
mempalace.yaml
entities.json

# La Piazza X posting tool — local post tracking
docs/business/marketing/twitter/.post-state.json

# Local test scratch (holds keys/secrets — NEVER commit)
tests/tmp/

# Blueprint media — heavy binaries live in GDrive, not git (keep the .md notes)
docs/blueprint/*.png
docs/blueprint/*.jpeg
docs/blueprint/*.jpg
docs/blueprint/*.pdf
docs/blueprint/*.html
docs/blueprint/*.ogg

# Marketing media — root-level frame exports + voice notes (the .html/.md/.srt
# sources + nested youtube-upload-kit thumbnails stay tracked; this is single-level)
docs/business/marketing/*.png
docs/business/marketing/*.ogg
docs/business/marketing/*.jpg

# Test-script PDF exports — generated runbook prints (the .html sources stay tracked)
docs/testing/test-scripts/*.pdf

# Generated workflow orchestration scripts (session artifacts — force-add or move
# to scripts/ if one becomes a keeper). settings.json stays tracked.
.claude/workflows/

# console-sweep run artifacts (regenerated each run)
tests/e2e/*-report.json

# YouTube uploader secrets (never commit)
scripts/yt_client_secret.json
scripts/yt_token.json

# Test outputs — generated, not source (test-scripts/ + *.md stay tracked)
# reports/: track the lightweight .txt twins + README (the "what we verified" log);
# ignore bulky screenshot-laden .html and any images.
docs/testing/reports/**/*.html
docs/testing/reports/**/*.png
docs/testing/reports/**/*.jpg
docs/testing/artifacts/
docs/testing/archive/

# Deploy build stamp (written per-deploy, not source)
src/static/build-sha.txt

# ====================================================================
# 🎬 BORN ONCE VIDEO RENDER ARTIFACTS
# Slides/shots are regenerable Puppeteer/slideshow frames (249M+).
# Only the YouTube kit (CAPTIONS.srt / DESCRIPTION.txt / TAGS.txt /
# YOUTUBE-KIT.md / thumbnail.png) is tracked per episode.
# ====================================================================
videos/**/assets/slides/
videos/**/assets/slides2/
videos/**/assets/shots/
videos/**/assets/concat.txt

# ====================================================================
# 🧪 BANCO TEST CAPTURES & EXPORTS (generated, not source)
# Receipts, Z-reports, test-sheet PDF prints, screenshots, voice
# notes, transcripts, data dumps. The .md/.html test-SHEET SOURCES
# stay tracked (they're the "best sheet ever" templates).
# ====================================================================
docs/testing/banco/**/*.pdf
docs/testing/banco/**/*.png
docs/testing/banco/**/*.jpeg
docs/testing/banco/**/*.jpg
docs/testing/banco/**/*.ogg
docs/testing/banco/**/*.csv
docs/testing/banco/**/*.json
docs/testing/banco/banco-pos-test-run*report.html
docs/testing/banco/banco-pos-test-run*report.txt

# Local inventory exports (real product-data dumps, regenerable)
docs/business/inventory/inventory-local-*.csv
docs/business/inventory/inventory-local-*.md
