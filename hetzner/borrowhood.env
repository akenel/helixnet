# BorrowHood UAT Environment (Hetzner)
# Used by borrowhood container in docker-compose.uat.yml

BH_APP_NAME=BorrowHood
BH_APP_URL=https://46.62.138.218:8443
BH_SECRET_KEY=borrowhood-uat-secret-key-change-in-production-2026
BH_DEBUG=true
BH_LOG_LEVEL=INFO

# Database (shared Postgres, separate database)
BH_DATABASE_URL=postgresql+asyncpg://borrowhood:borrowhood_pass@postgres:5432/borrowhood

# Keycloak (shared instance -- borrowhood realm)
BH_KC_URL=https://46.62.138.218
BH_KC_REALM=borrowhood
BH_KC_CLIENT_ID=borrowhood-web
BH_KC_CLIENT_SECRET=

# PayPal (sandbox for now)
BH_PAYPAL_CLIENT_ID=
BH_PAYPAL_CLIENT_SECRET=
BH_PAYPAL_MODE=sandbox
BH_PAYPAL_MERCHANT_EMAIL=angel.kenel@gmail.com

# Telegram
BH_TELEGRAM_ENABLED=false
BH_TELEGRAM_BOT_TOKEN=
