# Template for staging secrets.
# Copy to .env.staging on the Hetzner box and fill in.
# NEVER commit the real .env.staging -- it's in .gitignore.
#
# Diffs from prod .env:
#   - BH_ENVIRONMENT=staging
#   - BH_DATABASE_URL points at borrowhood_staging DB
#   - BH_KC_REALM=borrowhood-staging
#   - BH_SECRET_KEY is different (don't reuse prod's)
#   - BH_TELEGRAM_ENABLED=false (no real bot pings)
#   - BH_EMAIL_ENABLED=false (no real mail sending)
#   - Everything else can mirror prod.

# ===== Environment flag =====
BH_ENVIRONMENT=staging

# ===== Database =====
# Uses the same postgres container, different database.
# Password: generate a fresh one (e.g. openssl rand -base64 24)
BH_DATABASE_URL=postgresql+asyncpg://staging_user:<FILL-IN-STAGING-DB-PASSWORD>@postgres:5432/borrowhood_staging

# ===== App URL =====
BH_APP_URL=https://staging.lapiazza.app
BH_APP_NAME=La Piazza (staging)
BH_SECRET_KEY=<FILL-IN-DIFFERENT-FROM-PROD>
BH_DEBUG=false
BH_LOG_LEVEL=INFO

# ===== Community -- mirror prod =====
BH_COMMUNITY_NAME=Trapani, Sicily
BH_COMMUNITY_COUNTRY=IT
BH_COMMUNITY_CURRENCY=EUR
BH_COMMUNITY_TIMEZONE=Europe/Rome

# ===== Keycloak -- separate realm on the same instance =====
BH_KC_URL=https://staging.lapiazza.app
BH_KC_REALM=borrowhood-staging
BH_KC_CLIENT_ID=borrowhood-web
BH_KC_CLIENT_SECRET=<FILL-IN-FROM-KC-ADMIN-UI>

# ===== Minio -- shared bucket, files namespaced in the app =====
BH_MINIO_URL=minio:9000
BH_MINIO_ACCESS_KEY=<SAME-AS-PROD-OK>
BH_MINIO_SECRET_KEY=<SAME-AS-PROD-OK>
BH_MINIO_BUCKET=borrowhood

# ===== Notifications -- DISABLED on staging (no real user pings) =====
BH_TELEGRAM_ENABLED=false
BH_TELEGRAM_BOT_TOKEN=
BH_TELEGRAM_BOT_NAME=
BH_EMAIL_ENABLED=false
BH_RESEND_API_KEY=
BH_MAIL_FROM=La Piazza (staging) <noreply-staging@lapiazza.app>

# ===== Payments -- sandbox mode =====
BH_PAYPAL_MODE=sandbox
BH_PAYPAL_CLIENT_ID=
BH_PAYPAL_CLIENT_SECRET=
BH_STRIPE_SECRET_KEY=
BH_STRIPE_PUBLISHABLE_KEY=
BH_STRIPE_WEBHOOK_SECRET=

# ===== AI -- share prod keys (rate limits are on a single project) =====
BH_AI_PROVIDER=auto
BH_GOOGLE_API_KEY=<COPY-FROM-PROD>
BH_GEMINI_MODEL=gemini-2.5-flash
BH_GOOGLE_MAPS_API_KEY=<COPY-FROM-PROD>

# ===== LibreTranslate =====
BH_LIBRETRANSLATE_URL=http://libretranslate:5000
BH_LIBRETRANSLATE_ENABLED=true
