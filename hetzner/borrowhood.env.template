# ============================================================
# BorrowHood PROD Environment (Hetzner) -- TEMPLATE
# ============================================================
# Copy to hetzner/borrowhood.env on the Hetzner server and fill in.
# NEVER commit the real borrowhood.env -- it's in .gitignore.
#
# History note (2026-05-10): the previous borrowhood.env was tracked
# in this PUBLIC repo for ~3 months (commits 5ff5838 onward) with
# real secrets. All secrets named below MUST be rotated at least
# once before this template is used in anger again.
#
# To generate a strong random value:
#   openssl rand -base64 32   # for SECRET_KEY-style values
#   openssl rand -hex 16      # for shorter tokens
# ============================================================

# ===== App =====
BH_APP_NAME=La Piazza
BH_APP_URL=https://lapiazza.app
BH_SECRET_KEY=<ROTATE-FILL-IN-32-bytes-base64>
BH_DEBUG=false
BH_LOG_LEVEL=INFO

# ===== Database (shared Postgres, separate database) =====
BH_DATABASE_URL=postgresql+asyncpg://borrowhood:<ROTATE-DB-PASSWORD>@postgres:5432/borrowhood

# ===== Keycloak (shared instance -- borrowhood realm) =====
BH_KC_URL=https://lapiazza.app
BH_KC_REALM=borrowhood
BH_KC_CLIENT_ID=borrowhood-web
BH_KC_CLIENT_SECRET=<ROTATE-FROM-KC-ADMIN-UI>

# ===== PayPal (sandbox or live) =====
BH_PAYPAL_MODE=sandbox
BH_PAYPAL_CLIENT_ID=<ROTATE-FROM-PAYPAL-DEVELOPER-PORTAL>
BH_PAYPAL_CLIENT_SECRET=<ROTATE-FROM-PAYPAL-DEVELOPER-PORTAL>
BH_PAYPAL_MERCHANT_EMAIL=<your-paypal-email>

# ===== LibreTranslate (self-hosted translation container) =====
BH_LIBRETRANSLATE_URL=http://libretranslate:5000
BH_LIBRETRANSLATE_ENABLED=true

# ===== Telegram bot =====
BH_TELEGRAM_ENABLED=true
BH_TELEGRAM_BOT_TOKEN=<ROTATE-FROM-BOTFATHER>
BH_TELEGRAM_BOT_NAME=

# ===== Email (Resend) =====
BH_EMAIL_ENABLED=true
BH_RESEND_API_KEY=<ROTATE-FROM-RESEND-DASHBOARD>
BH_MAIL_FROM=La Piazza <noreply@lapiazza.app>

# ===== AI provider =====
BH_AI_PROVIDER=auto
BH_OLLAMA_URL=
BH_OLLAMA_KEY=
BH_OLLAMA_MODEL=

# ===== Keycloak Identity Providers (OAuth bridges) =====
KC_GITHUB_CLIENT_ID=<ROTATE-FROM-GITHUB-OAUTH-APP>
KC_GITHUB_CLIENT_SECRET=<ROTATE-FROM-GITHUB-OAUTH-APP>
KC_GOOGLE_CLIENT_ID=<ROTATE-FROM-GOOGLE-CLOUD-CONSOLE>
KC_GOOGLE_CLIENT_SECRET=<ROTATE-FROM-GOOGLE-CLOUD-CONSOLE>
