# BorrowHood -- port 443 (DEV Weekend Challenge)
:443 {
	tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem

	# Keycloak auth paths (BorrowHood needs these for OIDC login)
	handle /realms/* {
		reverse_proxy keycloak:8080
	}
	handle /resources/* {
		reverse_proxy keycloak:8080
	}
	handle /js/* {
		reverse_proxy keycloak:8080
	}

	# BorrowHood app (default)
	handle {
		reverse_proxy borrowhood:8000
	}
}
